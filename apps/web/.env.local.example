# Frontend environment variables for Vercel deployment

# Firebase Functions API URL (replace with your actual deployed URL)
NEXT_PUBLIC_API_URL=https://asia-southeast1-competitor-stalker.cloudfunctions.net/api
NEXTAUTH_API_URL=https://asia-southeast1-competitor-stalker.cloudfunctions.net/api

# NextAuth
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
